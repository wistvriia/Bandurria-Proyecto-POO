<?xml version="1.0" encoding="UTF-8"?>
<!--
  Carpeta 3 - Resto
  Infraestructura general del proyecto (parent, coordenadas, properties y build)
  mas las pruebas (JUnit 5 + Mockito).
-->
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>3.3.5</version>
        <relativePath/>
    </parent>

    <groupId>cl.ufro</groupId>
    <artifactId>redsocial-ufro</artifactId>
    <version>1.0.0</version>
    <name>redsocial-ufro</name>
    <description>Red social exclusiva para estudiantes de la Universidad de La Frontera</description>

    <properties>
        <java.version>17</java.version>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    </properties>

    <dependencies>
        <!-- Pruebas unitarias: JUnit 5 + Mockito (incluidos en el starter test) -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-test</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
            </plugin>

            <!-- Permite que Mockito/ByteBuddy funcionen en JDK muy recientes (25/26)
                 y silencia el aviso de carga dinamica del agente de Mockito. -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <configuration>
                    <argLine>-Dnet.bytebuddy.experimental=true -XX:+EnableDynamicAgentLoading</argLine>
                </configuration>
            </plugin>
        </plugins>
    </build>
</project>
